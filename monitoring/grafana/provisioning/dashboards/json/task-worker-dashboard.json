{
  "title": "Distributed Task Worker",
  "uid": "task-worker-overview",
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "API Latency (p95, seconds)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(taskworker_http_request_duration_seconds_bucket[1m])) by (le, route))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Queue Throughput (jobs by state)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "taskworker_bullmq_job_count{queue=\"heavy-computations-queue\"}",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ]
    }
  ]
}
