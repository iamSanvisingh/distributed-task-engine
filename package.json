{
  "name": "distributed-task-worker",
  "version": "1.0.0",
  "description": "Distributed Asynchronous Task Worker System — Express ingress gateway decoupled from a BullMQ/Redis worker cluster.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test:load": "node test/stress/load-metrics.test.js"
  },
  "keywords": ["bullmq", "redis", "express", "typescript", "distributed-systems"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bullmq": "^5.12.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "autocannon": "^7.15.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}
